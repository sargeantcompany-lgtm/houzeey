# Copy this to .env and fill in your values

# PostgreSQL — paste your Railway DATABASE_URL here
DATABASE_URL=postgresql://user:password@host:port/dbname

# JWT secret — generate a long random string
JWT_SECRET=your_super_secret_jwt_key_here

# Port (Railway sets this automatically)
PORT=3001

# Frontend URL for CORS (your Houzeey web app URL)
CLIENT_URL=https://www.houzeey.com

# Upload directory (Railway: mount a volume at /uploads for persistence)
UPLOAD_DIR=uploads

# SMTP Email — add these in Railway backend service Variables for email to work
# Without these, emails are logged to console only
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Houzeey" <no-reply@houzeey.com>
